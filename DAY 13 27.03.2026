<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Responsive Example</title>

  <style>
    /* 1. Box: 80% width, max 600px */
    .box {
      width: 80%;
      max-width: 600px;
      height: 150px;
      background-color: lightblue;
      margin: 20px auto;
    }

    /* 2. Paragraph with 1.5rem */
    p {
      font-size: 1.5rem;
    }

    /* 3. Heading using vw */
    h1 {
      font-size: 5vw;
    }

    /* 4. Media query */
    body {
      background-color: white;
    }

    @media (max-width: 768px) {
      body {
        background-color: lightgray;
      }
    }
  </style>
</head>

<body>

  <h1>Responsive Heading</h1>

  <div class="box"></div>

  <p>
    This paragraph uses 1.5rem font size.
  </p>

</body>
</html>
