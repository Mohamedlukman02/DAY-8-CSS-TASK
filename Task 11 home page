<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>CSS Methods Demo</title>

    <!-- Internal CSS -->
    <style>
        .internal {
            background-color: lightblue;
            color: darkblue;
            padding: 20px;
            margin: 10px;
            border: 2px solid blue;
        }
    </style>

    <!-- External CSS Link -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <h1>CSS Styling Methods</h1>

    <!-- Inline CSS -->
    <div style="background-color: lightcoral; color: white; padding: 20px; margin: 10px; border: 2px solid red;">
        <h2>Inline CSS</h2>
        <p>This section is styled using inline CSS.</p>
    </div>

    <!-- Internal CSS -->
    <div class="internal">
        <h2>Internal CSS</h2>
        <p>This section is styled using internal CSS.</p>
    </div>

    <!-- External CSS -->
    <div class="external">
        <h2>External CSS</h2>
        <p>This section is styled using external CSS.</p>
    </div>

</body>
</html>
