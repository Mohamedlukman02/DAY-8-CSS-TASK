<!DOCTYPE html>
<html>
<head>
    <title>CSS Basics Demo</title>

    <style>
        /* 1. Colors */
        .color-box {
            color: blue;              /* Text color */
            border: 2px solid red;    /* Border color */
            padding: 10px;
        }

        /* 2. Backgrounds */
        .background-box {
            background-color: lightyellow; /* Background color */
            background-image: url('https://via.placeholder.com/150');
            background-repeat: no-repeat;
            background-position: right;
            padding: 20px;
        }

        /* 3. Fonts */
        .font-box {
            font-family: Arial, sans-serif; /* Font family */
            font-size: 20px;                /* Font size */
        }

        /* 4. Text Styles */
        .text-style-box {
            font-weight: bold;     /* Bold */
            font-style: italic;    /* Italic */
            text-decoration: underline; /* Underline */
        }
    </style>

</head>
<body>

    <h1>MOHAMED LUKMAN </h1>

    <!-- Colors -->
    <div class="color-box">
    my native is mayiladuthurai.
    </div>

    <br>

    <!-- Background -->
    <div class="background-box">
        I am stadying at mam college of engineering
    </div>

    <br>

    <!-- Fonts -->
    <div class="font-box">
        This is the Font box
    </div>

    <br>

    <!-- Text Styles -->
    <div class="text-style-box">
        i love myself 
    </div>

</body>
</html>
